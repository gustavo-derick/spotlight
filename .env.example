# ─── Supabase ────────────────────────────────────────────────────────────────
# URL do seu projeto Supabase (Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co

# Chave pública anon (Settings > API > Project API keys > anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave service_role — NUNCA expor no client ou commitar (Settings > API > service_role)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── TMDB ─────────────────────────────────────────────────────────────────────
# Obtida em https://www.themoviedb.org/settings/api (API Read Access Token)
TMDB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── RapidAPI ─────────────────────────────────────────────────────────────────
# Sua chave do RapidAPI (painel em rapidapi.com/developer/apps)
RAPIDAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── App ──────────────────────────────────────────────────────────────────────
# URL base da aplicação (sem trailing slash)
# Em desenvolvimento: http://localhost:3000
# Em produção: https://spotlight.vercel.app (ou seu domínio)
NEXT_PUBLIC_APP_URL=http://localhost:3000
